<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_bg"
    tools:context=".OtpVerifyActivity">

    <!-- Animated Background Circles -->
    <View
        android:id="@+id/circle1"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/circle_bg_primary"
        android:alpha="0.15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.1" />

    <View
        android:id="@+id/circle2"
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:background="@drawable/circle_bg_accent"
        android:alpha="0.1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.9" />

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Verify OTP"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />
    </androidx.appcompat.widget.Toolbar>

    <!-- Step Indicator -->
    <TextView
        android:id="@+id/tvStepIndicator"
        style="@style/SmallText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 2 of 3"
        android:textColor="@color/primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp" />

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- OTP Icon -->
            <ImageView
                android:id="@+id/otpIcon"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:src="@drawable/ic_email_otp"
                android:contentDescription="OTP Icon"
                app:tint="@color/primary" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvOtpTitle"
                style="@style/Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="Verify OTP" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvOtpSubtitle"
                style="@style/BodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="We sent a 6-digit code to" />

            <!-- Email -->
            <TextView
                android:id="@+id/tvOtpEmail"
                style="@style/SmallText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:text="user@email.com"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- OTP Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/otpCard"
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- OTP Label -->
                    <TextView
                        style="@style/SmallText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter 6-Digit OTP"
                        android:layout_marginBottom="14dp" />

                    <!-- OTP Boxes -->
                    <LinearLayout
                        android:id="@+id/layoutOtpBoxes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="18dp">

                        <EditText
                            android:id="@+id/etOtp1"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:background="@drawable/otp_box_bg"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginEnd="6dp" />

                        <EditText
                            android:id="@+id/etOtp2"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:background="@drawable/otp_box_bg"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginEnd="6dp" />

                        <EditText
                            android:id="@+id/etOtp3"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:background="@drawable/otp_box_bg"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginEnd="6dp" />

                        <EditText
                            android:id="@+id/etOtp4"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:background="@drawable/otp_box_bg"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginEnd="6dp" />

                        <EditText
                            android:id="@+id/etOtp5"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:background="@drawable/otp_box_bg"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginEnd="6dp" />

                        <EditText
                            android:id="@+id/etOtp6"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:background="@drawable/otp_box_bg"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <!-- Countdown Timer -->
                    <TextView
                        android:id="@+id/tvCountdown"
                        style="@style/SmallText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="OTP expires in: 02:00"
                        android:layout_marginBottom="18dp" />

                    <!-- Verify Button -->
                    <Button
                        android:id="@+id/btnVerifyOtp"
                        style="@style/PrimaryButton"
                        android:layout_width="match_parent"
                        android:text="VERIFY OTP"
                        android:layout_marginBottom="16dp" />

                    <!-- Resend Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/BodyText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Didn't receive OTP? " />

                        <TextView
                            android:id="@+id/tvResendOtp"
                            style="@style/SmallText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resend"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Spacing -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>