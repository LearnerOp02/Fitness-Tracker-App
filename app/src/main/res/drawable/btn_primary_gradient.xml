<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#C73E55"
                android:endColor="#E94560"
                android:type="linear" />
            <corners android:radius="28dp" />
            <padding
                android:bottom="12dp"
                android:left="24dp"
                android:right="24dp"
                android:top="12dp" />
        </shape>
    </item>

    <!-- Enabled State -->
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#E94560"
                android:centerColor="#FF5E7A"
                android:endColor="#FF8E8E"
                android:type="linear" />
            <corners android:radius="28dp" />
            <padding
                android:bottom="12dp"
                android:left="24dp"
                android:right="24dp"
                android:top="12dp" />
        </shape>
    </item>

    <!-- Disabled State -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#66333355" />
            <corners android:radius="28dp" />
            <padding
                android:bottom="12dp"
                android:left="24dp"
                android:right="24dp"
                android:top="12dp" />
        </shape>
    </item>
</selector>