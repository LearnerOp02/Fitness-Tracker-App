<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ==================== THEMES ==================== -->

    <!-- Base application theme -->
    <style name="Theme.FitnessProject" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/surface_dark</item>
        <item name="colorSecondaryVariant">@color/surface</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <!-- No action bar theme — used by all screens -->
    <style name="Theme.FitnessProject.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/surface_dark</item>
        <item name="colorSecondaryVariant">@color/surface</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- AppTheme (for backward compatibility) -->
    <style name="AppTheme" parent="Theme.FitnessProject.NoActionBar" />

    <!-- Splash Theme -->
    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_gradient_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowAnimationStyle">@style/SplashAnimation</item>
    </style>

    <!-- Splash Animation -->
    <style name="SplashAnimation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <!-- Transparent Theme -->
    <style name="TransparentTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="colorPrimary">@color/primary</item>
    </style>

    <!-- Translucent dialog theme (alias for TransparentTheme) -->
    <style name="Theme.AppCompat.Translucent" parent="TransparentTheme" />

    <!-- ==================== BUTTON STYLES ==================== -->

    <!-- Primary Button Style -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/btn_primary_gradient</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <!-- Outline Button Style -->
    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:background">@drawable/btn_outline_gradient</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">26dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- Filter Button Style (Active) -->
    <style name="FilterButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/btn_primary_gradient</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">20dp</item>
    </style>

    <!-- Filter Button Style (Inactive) -->
    <style name="FilterButtonInactive" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">20dp</item>
    </style>

    <!-- ==================== TEXT STYLES ==================== -->

    <!-- Heading 1 - 48sp (App Name) -->
    <style name="Heading1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Heading 2 - 28sp (Screen Titles) -->
    <style name="Heading2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Heading 3 - 18sp (Section Titles) -->
    <style name="Heading3" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Body Text - 14sp (Regular text) -->
    <style name="BodyText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-regular</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Small Text - 12sp (Labels, hints) -->
    <style name="SmallText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ==================== CARD STYLES ==================== -->

    <!-- Main Card Style (24dp corner radius) -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardPreventCornerOverlap">true</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <!-- Small Card Style (20dp corner radius) -->
    <style name="SmallCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardPreventCornerOverlap">true</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <!-- ==================== INPUT FIELD STYLES ==================== -->

    <!-- TextInputLayout Style -->
    <style name="TextInputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_light</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintEnabled">false</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="endIconTint">@color/primary</item>
        <item name="startIconTint">@color/primary</item>
    </style>

    <!-- ==================== DIALOG STYLES ==================== -->

    <!-- Custom Alert Dialog Style -->
    <style name="CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">@color/surface</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="android:windowBackground">@drawable/splash_gradient_bg</item>
    </style>

    <!-- Positive Button Style (Confirm) -->
    <style name="PositiveButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Negative Button Style (Cancel) -->
    <style name="NegativeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ==================== TOOLBAR STYLES ==================== -->

    <!-- Toolbar Title Style -->
    <style name="ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ==================== PROGRESS BAR STYLES ==================== -->

    <!-- Circular Progress Style -->
    <style name="CircularProgress" parent="Widget.AppCompat.ProgressBar">
        <item name="android:indeterminateTint">@color/primary</item>
        <item name="android:indeterminateTintMode">src_atop</item>
    </style>

    <!-- Horizontal Progress Style -->
    <style name="HorizontalProgress" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressTint">@color/primary</item>
        <item name="android:progressBackgroundTint">@color/stroke</item>
        <item name="android:progressTintMode">src_atop</item>
    </style>

    <!-- ==================== SWITCH STYLES ==================== -->

    <!-- Switch Style -->
    <style name="SwitchStyle" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:trackTint">@color/primary</item>
        <item name="android:thumbTint">#FFFFFF</item>
        <item name="android:trackTintMode">src_atop</item>
    </style>

    <!-- ==================== RADIO BUTTON STYLES ==================== -->

    <!-- Radio Button Style -->
    <style name="RadioButtonStyle" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:buttonTint">@color/primary</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ==================== CHECKBOX STYLES ==================== -->

    <!-- CheckBox Style -->
    <style name="CheckBoxStyle" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:buttonTint">@color/primary</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-regular</item>
    </style>

    <!-- ==================== SPINNER STYLES ==================== -->

    <!-- Spinner Style -->
    <style name="SpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-regular</item>
    </style>

    <!-- ==================== CHIP STYLES ==================== -->

    <!-- Adaptive Chip Style -->
    <style name="AdaptiveChipStyle" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="chipBackgroundColor">#33E94560</item>
        <item name="chipCornerRadius">12dp</item>
        <item name="chipStrokeColor">@color/primary</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- ==================== FLOATING ACTION BUTTON STYLES ==================== -->

    <!-- FAB Style -->
    <style name="FabStyle" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">#FFFFFF</item>
        <item name="fabSize">normal</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- Mini FAB Style -->
    <style name="MiniFabStyle" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">#FFFFFF</item>
        <item name="fabSize">mini</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- ==================== TAB LAYOUT STYLES ==================== -->

    <!-- Tab Layout Style -->
    <style name="TabLayoutStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabBackground">@android:color/transparent</item>
    </style>

    <!-- ==================== BOTTOM SHEET STYLES ==================== -->

    <!-- Bottom Sheet Style -->
    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">@color/surface</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- ==================== DIVIDER STYLES ==================== -->

    <!-- Divider Style -->
    <style name="DividerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/stroke</item>
    </style>

</resources>